generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TESTER
  DEVELOPER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(TESTER)

  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  lastLoginAt         DateTime?

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  passwordResetTokens PasswordResetToken[]
  passwordHistory     PasswordHistory[]

  testCases  TestCase[]
  executions Execution[] @relation("UserExecutions")

  testRunsCreated  TestRun[]
  assignedRunCases TestRunTestCase[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestCase {
  id          String @id @default(uuid())
  testCaseId  String @unique
  title       String @db.VarChar(200)
  description String

  module   String
  priority TestCasePriority
  severity TestCaseSeverity
  type     TestCaseType
  status   TestCaseStatus

  preConditions           String?
  testDataRequirements    String?
  environmentRequirements String?
  postConditions          String?
  cleanupSteps            String?

  estimatedDuration    Int?
  automationStatus     AutomationStatus
  automationScriptLink String?

  tags    String[]
  version Int      @default(1)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  steps TestStep[]

  executions   Execution[]
  testRunCases TestRunTestCase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestStep {
  id         String   @id @default(uuid())
  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  stepNumber     Int
  action         String
  testData       String?
  expectedResult String

  createdAt DateTime @default(now())
}

model TestRun {
  id          String        @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      TestRunStatus @default(PLANNED)

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  testCases TestRunTestCase[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model TestRunTestCase {
  id String @id @default(uuid())

  testRun   TestRun @relation(fields: [testRunId], references: [id])
  testRunId String

  testCase   TestCase @relation(fields: [testCaseId], references: [id])
  testCaseId String

  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  assignedToId String?

  status TestRunCaseStatus @default(PENDING)
}

enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TestRunCaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseSeverity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  INTEGRATION
  UAT
  PERFORMANCE
  SECURITY
  USABILITY
}

enum TestCaseStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  DEPRECATED
  ARCHIVED
}

enum AutomationStatus {
  NOT_AUTOMATED
  IN_PROGRESS
  AUTOMATED
  CANNOT_AUTOMATE
}

model Execution {
  id           String   @id @default(uuid())
  testCaseId   String
  testCase     TestCase @relation(fields: [testCaseId], references: [id])
  executedById String
  executedBy   User     @relation("UserExecutions", fields: [executedById], references: [id])

  status        ExecutionStatus @default(IN_PROGRESS)
  overallResult StepStatus?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  steps ExecutionStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExecutionStep {
  id          String    @id @default(uuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id])

  stepNumber     Int
  action         String
  expectedResult String

  actualResult String?
  status       StepStatus?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidenceUrl String?   // file path or URL
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
}

enum StepStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}
