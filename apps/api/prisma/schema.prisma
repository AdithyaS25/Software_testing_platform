generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  failedLoginAttempts    Int                     @default(0)
  lockUntil              DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @default(now()) @updatedAt
  role                   UserRole                @default(TESTER)
  assignedBugs           Bug[]
  resolvedBugs           Bug[]                   @relation("ResolvedBugs")
  bugComments            BugComment[]
  executions             Execution[]             @relation("UserExecutions")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  passwordHistory        PasswordHistory[]
  passwordResetTokens    PasswordResetToken[]
  refreshTokens          RefreshToken[]
  testCases              TestCase[]
  testRunsCreated        TestRun[]
  assignedRunCases       TestRunTestCase[]
  testSuites             TestSuite[]
  suiteExecutions        TestSuiteExecution[]
  projectMembers         ProjectMember[]
  ownedProjects          Project[]               @relation("ProjectOwner")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestCase {
  id                      String              @id @default(uuid())
  testCaseId              String              @unique
  title                   String              @db.VarChar(200)
  description             String
  module                  String
  priority                TestCasePriority
  severity                TestCaseSeverity
  type                    TestCaseType
  status                  TestCaseStatus
  preConditions           String?
  testDataRequirements    String?
  environmentRequirements String?
  postConditions          String?
  cleanupSteps            String?
  estimatedDuration       Int?
  automationStatus        AutomationStatus
  automationScriptLink    String?
  tags                    String[]
  version                 Int                 @default(1)
  createdById             String
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  projectId               String
  bugs                    Bug[]
  executions              Execution[]
  createdBy               User                @relation(fields: [createdById], references: [id])
  project                 Project             @relation(fields: [projectId], references: [id])
  testRunCases            TestRunTestCase[]
  steps                   TestStep[]
  suiteRelations          TestSuiteTestCase[]
}

model TestStep {
  id             String   @id @default(uuid())
  testCaseId     String
  stepNumber     Int
  action         String
  testData       String?
  expectedResult String
  createdAt      DateTime @default(now())
  testCase       TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
}

model TestRun {
  id                String             @id @default(uuid())
  name              String
  description       String?
  startDate         DateTime
  endDate           DateTime
  status            TestRunStatus      @default(PLANNED)
  createdById       String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  projectId         String
  executions        Execution[]
  createdBy         User               @relation(fields: [createdById], references: [id])
  project           Project            @relation(fields: [projectId], references: [id])
  testCases         TestRunTestCase[]
  milestoneTestRuns MilestoneTestRun[]
}

model TestRunTestCase {
  id           String            @id @default(uuid())
  testRunId    String
  testCaseId   String
  assignedToId String?
  status       TestRunCaseStatus @default(PENDING)
  assignedTo   User?             @relation(fields: [assignedToId], references: [id])
  testCase     TestCase          @relation(fields: [testCaseId], references: [id])
  testRun      TestRun           @relation(fields: [testRunId], references: [id])
}

model Execution {
  id               String              @id @default(uuid())
  testCaseId       String
  executedById     String
  status           ExecutionStatus     @default(IN_PROGRESS)
  overallResult    StepStatus?
  startedAt        DateTime            @default(now())
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  suiteExecutionId String?
  testRunId        String?
  bugs             Bug[]
  executedBy       User                @relation("UserExecutions", fields: [executedById], references: [id])
  suiteExecution   TestSuiteExecution? @relation(fields: [suiteExecutionId], references: [id])
  testCase         TestCase            @relation(fields: [testCaseId], references: [id])
  testRun          TestRun?            @relation(fields: [testRunId], references: [id])
  steps            ExecutionStep[]
}

model ExecutionStep {
  id             String      @id @default(uuid())
  executionId    String
  stepNumber     Int
  action         String
  expectedResult String
  actualResult   String?
  status         StepStatus?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  evidenceUrl    String?
  bugs           Bug[]
  execution      Execution   @relation(fields: [executionId], references: [id])
}

model Bug {
  id               String         @id @default(uuid())
  bugId            String         @unique
  title            String
  description      String
  expectedBehavior String
  actualBehavior   String
  severity         BugSeverity
  priority         BugPriority
  status           BugStatus      @default(NEW)
  testCaseId       String?
  executionId      String?
  executionStepId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  affectedVersion  String?
  assignedToId     String?
  environment      String?
  stepsToReproduce String?
  fixNotes         String?
  resolvedAt       DateTime?
  resolvedById     String?
  projectId        String
  assignedTo       User?          @relation(fields: [assignedToId], references: [id])
  execution        Execution?     @relation(fields: [executionId], references: [id])
  executionStep    ExecutionStep? @relation(fields: [executionStepId], references: [id])
  project          Project        @relation(fields: [projectId], references: [id])
  resolvedBy       User?          @relation("ResolvedBugs", fields: [resolvedById], references: [id])
  testCase         TestCase?      @relation(fields: [testCaseId], references: [id])
  comments         BugComment[]
}

model BugComment {
  id        String   @id @default(uuid())
  content   String
  bugId     String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  bug       Bug      @relation(fields: [bugId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id                    String  @id @default(uuid())
  userId                String  @unique
  emailBugAssigned      Boolean @default(true)
  emailBugStatusChanged Boolean @default(true)
  emailTestAssigned     Boolean @default(true)
  emailCommentMention   Boolean @default(true)
  emailRetestRequested  Boolean @default(true)
  inAppBugAssigned      Boolean @default(true)
  inAppBugStatusChanged Boolean @default(true)
  inAppTestAssigned     Boolean @default(true)
  inAppCommentMention   Boolean @default(true)
  inAppRetestRequested  Boolean @default(true)
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestSuite {
  id              String               @id @default(uuid())
  name            String
  description     String?
  createdById     String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  module          String?
  parentId        String?
  archivedAt      DateTime?
  isArchived      Boolean              @default(false)
  projectId       String
  createdBy       User                 @relation(fields: [createdById], references: [id])
  parent          TestSuite?           @relation("SuiteHierarchy", fields: [parentId], references: [id])
  children        TestSuite[]          @relation("SuiteHierarchy")
  project         Project              @relation(fields: [projectId], references: [id])
  suiteExecutions TestSuiteExecution[]
  testCases       TestSuiteTestCase[]
}

model TestSuiteTestCase {
  id         String    @id @default(uuid())
  suiteId    String
  testCaseId String
  position   Int
  createdAt  DateTime  @default(now())
  suite      TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  testCase   TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([suiteId, testCaseId])
}

model TestSuiteExecution {
  id            String               @id @default(uuid())
  suiteId       String
  executedById  String
  executionMode SuiteExecutionMode
  status        SuiteExecutionStatus
  totalTests    Int
  passed        Int                  @default(0)
  failed        Int                  @default(0)
  blocked       Int                  @default(0)
  skipped       Int                  @default(0)
  startedAt     DateTime             @default(now())
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  executions    Execution[]
  executedBy    User                 @relation(fields: [executedById], references: [id])
  suite         TestSuite            @relation(fields: [suiteId], references: [id])
}

model Project {
  id           String               @id @default(cuid())
  name         String
  description  String?
  key          String               @unique
  status       ProjectStatus        @default(ACTIVE)
  ownerId      String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  bugs         Bug[]
  testCases    TestCase[]
  testRuns     TestRun[]
  testSuites   TestSuite[]
  milestones   Milestone[]
  customFields ProjectCustomField[]
  environments ProjectEnvironment[]
  members      ProjectMember[]
  owner        User                 @relation("ProjectOwner", fields: [ownerId], references: [id])

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectEnvironment {
  id        String  @id @default(cuid())
  projectId String
  name      String
  url       String?
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_environments")
}

model ProjectCustomField {
  id        String          @id @default(cuid())
  projectId String
  name      String
  fieldType CustomFieldType @default(TEXT)
  options   String[]
  required  Boolean         @default(false)
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_custom_fields")
}

model Milestone {
  id             String             @id @default(cuid())
  projectId      String
  name           String
  description    String?
  targetDate     DateTime
  passRateTarget Float?
  status         MilestoneStatus    @default(UPCOMING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  testRuns       MilestoneTestRun[]
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model MilestoneTestRun {
  milestoneId String
  testRunId   String
  linkedAt    DateTime  @default(now())
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  testRun     TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  @@id([milestoneId, testRunId])
  @@map("milestone_test_runs")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  MISSED
}

enum CustomFieldType {
  TEXT
  NUMBER
  DROPDOWN
  DATE
  BOOLEAN
}

enum SuiteExecutionMode {
  SEQUENTIAL
  PARALLEL
}

enum SuiteExecutionStatus {
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  TESTER
  DEVELOPER
  ADMIN
}

enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TestRunCaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseSeverity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  INTEGRATION
  UAT
  PERFORMANCE
  SECURITY
  USABILITY
}

enum TestCaseStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  DEPRECATED
  ARCHIVED
}

enum AutomationStatus {
  NOT_AUTOMATED
  IN_PROGRESS
  AUTOMATED
  CANNOT_AUTOMATE
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

enum StepStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

enum BugSeverity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  P1_URGENT
  P2_HIGH
  P3_MEDIUM
  P4_LOW
}

enum BugStatus {
  NEW
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
  WONT_FIX
  DUPLICATE
}

enum NotificationType {
  BUG_ASSIGNED
  BUG_STATUS_CHANGED
  TEST_RUN_ASSIGNED
  COMMENT_MENTION
  RETEST_REQUESTED
}
