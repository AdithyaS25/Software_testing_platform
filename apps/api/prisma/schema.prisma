generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  failedLoginAttempts Int                  @default(0)
  lockUntil           DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  role                UserRole             @default(TESTER)
  executions          Execution[]          @relation("UserExecutions")
  passwordHistory     PasswordHistory[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  testCases           TestCase[]
  testRunsCreated     TestRun[]
  assignedRunCases    TestRunTestCase[]
  assignedBugs        Bug[]
  resolvedBugs        Bug[]                @relation("ResolvedBugs")
  bugComments         BugComment[]
  testSuites          TestSuite[]
  suiteExecutions     TestSuiteExecution[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  hash      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestCase {
  id                      String            @id @default(uuid())
  testCaseId              String            @unique
  title                   String            @db.VarChar(200)
  description             String
  module                  String
  priority                TestCasePriority
  severity                TestCaseSeverity
  type                    TestCaseType
  status                  TestCaseStatus
  preConditions           String?
  testDataRequirements    String?
  environmentRequirements String?
  postConditions          String?
  cleanupSteps            String?
  estimatedDuration       Int?
  automationStatus        AutomationStatus
  automationScriptLink    String?
  tags                    String[]
  version                 Int               @default(1)
  createdById             String
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  executions              Execution[]
  createdBy               User              @relation(fields: [createdById], references: [id])
  testRunCases            TestRunTestCase[]
  steps                   TestStep[]
  bugs                    Bug[]
  testSuites              TestSuite[]
}

model TestStep {
  id             String   @id @default(uuid())
  testCaseId     String
  stepNumber     Int
  action         String
  testData       String?
  expectedResult String
  createdAt      DateTime @default(now())
  testCase       TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
}

model TestRun {
  id          String            @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      TestRunStatus     @default(PLANNED)
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   User              @relation(fields: [createdById], references: [id])
  testCases   TestRunTestCase[]
}

model TestRunTestCase {
  id           String            @id @default(uuid())
  testRunId    String
  testCaseId   String
  assignedToId String?
  status       TestRunCaseStatus @default(PENDING)
  assignedTo   User?             @relation(fields: [assignedToId], references: [id])
  testCase     TestCase          @relation(fields: [testCaseId], references: [id])
  testRun      TestRun           @relation(fields: [testRunId], references: [id])
}

model Execution {
  id               String              @id @default(uuid())
  testCaseId       String
  executedById     String
  status           ExecutionStatus     @default(IN_PROGRESS)
  overallResult    StepStatus?
  startedAt        DateTime            @default(now())
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  executedBy       User                @relation("UserExecutions", fields: [executedById], references: [id])
  testCase         TestCase            @relation(fields: [testCaseId], references: [id])
  steps            ExecutionStep[]
  bugs             Bug[]
  suiteExecutionId String?
  suiteExecution   TestSuiteExecution? @relation(fields: [suiteExecutionId], references: [id])
}

model ExecutionStep {
  id             String      @id @default(uuid())
  executionId    String
  stepNumber     Int
  action         String
  expectedResult String
  actualResult   String?
  status         StepStatus?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  evidenceUrl    String?
  execution      Execution   @relation(fields: [executionId], references: [id])
  bugs           Bug[]
}

model Bug {
  id               String  @id @default(uuid())
  bugId            String  @unique
  title            String
  description      String
  stepsToReproduce String?
  expectedBehavior String
  actualBehavior   String

  environment     String?
  affectedVersion String?

  severity BugSeverity
  priority BugPriority
  status   BugStatus   @default(NEW)

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  testCaseId      String?
  executionId     String?
  executionStepId String?

  testCase      TestCase?      @relation(fields: [testCaseId], references: [id])
  execution     Execution?     @relation(fields: [executionId], references: [id])
  executionStep ExecutionStep? @relation(fields: [executionStepId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fixNotes     String?
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?        @relation("ResolvedBugs", fields: [resolvedById], references: [id])
  comments     BugComment[]
}

model BugComment {
  id      String @id @default(uuid())
  content String

  bugId String
  bug   Bug    @relation(fields: [bugId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TestSuite {
  id          String  @id @default(uuid())
  name        String
  description String?
  module      String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Many-to-many with TestCase
  testCases TestCase[]

  // Hierarchical (Self-relation)
  parentId String?
  parent   TestSuite?  @relation("SuiteHierarchy", fields: [parentId], references: [id])
  children TestSuite[] @relation("SuiteHierarchy")

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  suiteExecutions TestSuiteExecution[]
}

model TestSuiteExecution {
  id      String    @id @default(uuid())
  suiteId String
  suite   TestSuite @relation(fields: [suiteId], references: [id])

  executedById String
  executedBy   User   @relation(fields: [executedById], references: [id])

  executionMode SuiteExecutionMode
  status        SuiteExecutionStatus

  totalTests Int
  passed     Int @default(0)
  failed     Int @default(0)
  blocked    Int @default(0)
  skipped    Int @default(0)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  executions Execution[]

  createdAt DateTime @default(now())
}

enum SuiteExecutionMode {
  SEQUENTIAL
  PARALLEL
}

enum SuiteExecutionStatus {
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  TESTER
  DEVELOPER
  ADMIN
}

enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TestRunCaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TestCasePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TestCaseSeverity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum TestCaseType {
  FUNCTIONAL
  REGRESSION
  SMOKE
  INTEGRATION
  UAT
  PERFORMANCE
  SECURITY
  USABILITY
}

enum TestCaseStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  DEPRECATED
  ARCHIVED
}

enum AutomationStatus {
  NOT_AUTOMATED
  IN_PROGRESS
  AUTOMATED
  CANNOT_AUTOMATE
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

enum StepStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

enum BugSeverity {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum BugPriority {
  P1_URGENT
  P2_HIGH
  P3_MEDIUM
  P4_LOW
}

enum BugStatus {
  NEW
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
  WONT_FIX
  DUPLICATE
}
